# OpenClaw .env example (v2.0 Soft Execution Engine)
#
# Quick start:
# 1) Copy this file to `.env`
# 2) Fill in the values marked as required
# 3) Keep real secrets out of git — .env is already in .gitignore
#
# Env-source precedence (highest -> lowest):
# process env, ./.env, ~/.openclaw/.env, then openclaw.json `env` block.
# Existing non-empty process env vars are not overridden by dotenv/config env loading.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Required — generate with:
#   PowerShell: -join (1..48 | % { '{0:x}' -f (Get-Random -Max 16) })
#   Linux/Mac:  openssl rand -hex 24
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token

# Optional alternative auth mode (use token OR password, not both).
# OPENCLAW_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Gateway bind mode: loopback (本机 only) | lan (局域网可访问) | tailscale
OPENCLAW_GATEWAY_BIND=lan

# Path overrides
OPENCLAW_CONFIG_DIR=./config
OPENCLAW_WORKSPACE_DIR=./workspace

# Optional: import missing keys from your login shell profile.
# OPENCLAW_LOAD_SHELL_ENV=1
# OPENCLAW_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Multi-Expert Routing Matrix API Keys (MATRIX)
# -----------------------------------------------------------------------------
# 上游兼容 OpenAI 规范的接口地址 (如 SiliconFlow, DeepSeek官方, 或本地 Ollama)
OPENAI_COMPATIBLE_HOST=api.siliconflow.cn

# 细分领域专家 API Key（配合 proxy.js 和 ask_expert.cjs 实现 DAG 路由调度）
MATRIX_TEXT_API_KEY=sk-...
MATRIX_TOOL_API_KEY=sk-...       # 专用于工具调用的独立计费池
MATRIX_VISION_API_KEY=sk-...     # 视觉感知模型
MATRIX_REASONING_API_KEY=sk-...  # 推理大脑 (如 DeepSeek-R1)
MATRIX_CODE_API_KEY=sk-...       # 代码专家 (如 Qwen3-Coder)
MATRIX_EMBED_API_KEY=sk-...      # 记忆向量化模型

# 可选：如果其他厂商的模型名称与默认不同，请在此覆盖
# MATRIX_TEXT_MODEL=deepseek-chat
# MATRIX_REASONING_MODEL=deepseek-reasoner

# -----------------------------------------------------------------------------
# v2.0 Dual-Engine Web Fetcher (web_fetch.cjs)
# -----------------------------------------------------------------------------
# Engine 1: Jina AI (用于轻量极速的 search 和 read)
JINA_API_KEY=jina_...

# Engine 2: Firecrawl (用于重型的复杂 JS 渲染和深度 scrape)
FIRECRAWL_API_KEY=fc-...

# -----------------------------------------------------------------------------
# Network Proxy (网络代理配置)
# -----------------------------------------------------------------------------
# 如有需要，请取消注释并填入你的本地代理地址
# OPENCLAW_ALL_PROXY=http://127.0.0.1:7890

# -----------------------------------------------------------------------------
# Other model provider API keys (optional)
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...

# -----------------------------------------------------------------------------
# Channels（按需启用，不用的保持注释）
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optional channel env fallbacks
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com

# -----------------------------------------------------------------------------
# Tailscale（外网访问，可选）
# -----------------------------------------------------------------------------
# 前往 https://login.tailscale.com/admin/settings/keys 生成 Auth Key
# OPENCLAW_TAILSCALE_AUTH_KEY=tskey-auth-...

# -----------------------------------------------------------------------------
# External Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# ELEVENLABS_API_KEY=...
# DEEPGRAM_API_KEY=...